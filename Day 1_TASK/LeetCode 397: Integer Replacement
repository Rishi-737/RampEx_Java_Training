LeetCode 397: Integer Replacement

class Solution {
    public int integerReplacement(int n) {
    long num=n;
    int c=0;
    while(num>1){
        if(num%2==0){
            num/=2;
        }
        else if(num<4||num%4==1){
            num=num-1;
        }else {
            num=num+1;
        }
        c++;
    }
    return c;
    }
}
