Leetcode 2455: Average Value of Even Numbers That Are Divisible by Three

class Solution {
    public int averageValue(int[] nums) {
        int es=0;
        int c=0;
        for(int i=0;i<nums.length;i++){
            if(nums[i]%6==0){
            es+=nums[i];
            c++;
            }
        }
        if(c>0){
            return es/c;
        }
        else{
            return 0;
        }
    }
}
