Leetcode 1217: Minimum Cost to Move Chips to The Same Position 

class Solution {
    public int minCostToMoveChips(int[] position) {
      int oc=0;
      int ec=0;
      for(int i=0;i<position.length;i++){
        if(position[i]%2==0){
            ec++;
        }
        else{
            oc++;
        }
      }  
      return Math.min(oc,ec);
    }
}
