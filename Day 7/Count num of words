Count num of words

import java.util.Scanner;
public class Main
{
	public static void main(String[] args) {
	  Scanner in=new Scanner(System.in);
		String s=in.nextLine();
		boolean flag= true; int count=0;
		for(int i=0;i<s.length();i++){
		    char c= s.charAt(i);
		    if(c!=' '){
		        if(flag==true){
		            count++;
		            flag=false;
		        }
		    }
		    else{
		        flag=true;
		    }
		    
		}
		System.out.print(count);
	}
}
